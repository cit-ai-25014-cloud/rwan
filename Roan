#include <iostream>
using namespace std;

int main() {
    int arr[8] = {45, 12, 89, 7, 54, 23, 76, 31};
    int target;
    int sum = 0;
    float avg = 0;
    int max = arr[0];
    int min = arr[0];
    int even = 0;
    int odd = 0;
    int found = 0;

    cout << "--- DISPLAYING ARRAY DATA ---" << endl;
    for (int i = 0; i < 8; i++) {
        cout << "Index [" << i << "] = " << arr[i] << endl;
    }

    for (int i = 0; i < 8; i++) {
        sum = sum + arr[i];
        if (arr[i] > max) {
            max = arr[i];
        }
        if (arr[i] < min) {
            min = arr[i];
        }
        if (arr[i] % 2 == 0) {
            even++;
        } else {
            odd++;
        }
    }
    avg = sum / 8.0;

    cout << "--- STATISTICAL REPORT ---" << endl;
    cout << "Total Sum: " << sum << endl;
    cout << "Average  : " << avg << endl;
    cout << "Maximum  : " << max << endl;
    cout << "Minimum  : " << min << endl;
    cout << "Evens    : " << even << endl;
    cout << "Odds     : " << odd << endl;

    cout << "--- SEARCH OPERATION ---" << endl;
    cout << "Enter a number to find: ";
    cin >> target;

    for (int i = 0; i < 8; i++) {
        if (arr[i] == target) {
            cout << "Success: Found at index [" << i << "]" << endl;
            found = 1;
            break;
        }
    }

    if (found == 0) {
        cout << "Result: Number not found" << endl;
    }

    cout << "------------------------" << endl;
    return 0;
}
